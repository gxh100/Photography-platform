<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.cl.dao.SheyingzuopinDao">

	<!-- 可根据自己的需求，是否要使用 -->
    <resultMap type="com.cl.entity.SheyingzuopinEntity" id="sheyingzuopinMap">
        <result property="zuopinmingcheng" column="zuopinmingcheng"/>
        <result property="zuopinfenlei" column="zuopinfenlei"/>
        <result property="biaoqian" column="biaoqian"/>
        <result property="sheyingdidian" column="sheyingdidian"/>
        <result property="sheyingshijian" column="sheyingshijian"/>
        <result property="fengmian" column="fengmian"/>
        <result property="sheyingzuopin" column="sheyingzuopin"/>
        <result property="fabushijian" column="fabushijian"/>
        <result property="sheyingshizhanghao" column="sheyingshizhanghao"/>
        <result property="sheyingshixingming" column="sheyingshixingming"/>
        <result property="zuopinyingjianjie" column="zuopinyingjianjie"/>
        <result property="thumbsupNumber" column="thumbsup_number"/>
        <result property="crazilyNumber" column="crazily_number"/>
        <result property="storeupNumber" column="storeup_number"/>
        <result property="discussNumber" column="discuss_number"/>
        <result property="clicktime" column="clicktime"/>
        <result property="sfsh" column="sfsh"/>
        <result property="shhf" column="shhf"/>
    </resultMap>

    <select id="selectListView"
		resultType="com.cl.entity.view.SheyingzuopinView" >

		SELECT  sheyingzuopin.* FROM sheyingzuopin  sheyingzuopin 	        
        <where> 1=1 ${ew.sqlSegment}</where>
	</select>
	
	<select id="selectView"
		resultType="com.cl.entity.view.SheyingzuopinView" >
		SELECT * FROM sheyingzuopin  sheyingzuopin <where> 1=1 ${ew.sqlSegment}</where>
	</select>



    <select id="selectValue" resultType="map" >
        SELECT ${params.xColumn}, ROUND(sum(${params.yColumn}),1) total FROM sheyingzuopin
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.xColumn}
        limit 10
    </select>

    <select id="selectTimeStatValue" resultType="map" >
        <if test = 'params.timeStatType == "日"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m-%d') ${params.xColumn}, sum(${params.yColumn}) total FROM sheyingzuopin
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m-%d')
        </if>
        <if test = 'params.timeStatType == "月"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y-%m') ${params.xColumn}, sum(${params.yColumn}) total FROM sheyingzuopin
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y-%m')
        </if>
        <if test = 'params.timeStatType == "年"'>
                SELECT DATE_FORMAT(${params.xColumn},'%Y') ${params.xColumn}, sum(${params.yColumn}) total FROM sheyingzuopin
                <where> 1=1 ${ew.sqlSegment}</where>
                group by DATE_FORMAT(${params.xColumn},'%Y')
        </if>
    </select>

    <select id="selectGroup" resultType="map" >
        SELECT ${params.column} , count(1) total FROM sheyingzuopin
        <where> 1=1 ${ew.sqlSegment}</where>
        group by ${params.column}
        limit 10
    </select>



</mapper>
